DATABASE_URL=postgresql+psycopg://portal:portal@localhost:5432/portal
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# Telegram bot token (optional for MVP)
TELEGRAM_BOT_TOKEN=

# Файлы скриншотов (Docker: смонтированный том)
MEDIA_ROOT=/data/media

# Серверный ИИ (Ollama). В docker-compose по умолчанию: http://ollama:11434
# Локально без Docker оставьте пустым или укажите http://127.0.0.1:11434
OLLAMA_BASE_URL=
# Текстовые сводки — линейка Gemma 3n E4B (IT) в Ollama
OLLAMA_MODEL=gemma3n:e4b
# Скриншоты — multimodal Gemma 3 (HF google/gemma-3n-E4b-it в Ollama без vision; для картинок — gemma3)
OLLAMA_VISION_MODEL=gemma3:4b-it-q4_K_M

